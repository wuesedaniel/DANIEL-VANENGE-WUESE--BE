/**
 * Convert a string to title case
 * First letter of each word capitalized, rest lowercase
 * @param {string} str - Input string
 * @returns {string} - Title cased string or error message
 */
function toTitleCase(str) {
    // Input validation
    if (typeof str !== "string") {
        return `ERROR: Expected string, received ${typeof str}`;
    }

    if (str.length === 0) {
        return ""; // Empty string remains empty
    }

    // Split by spaces, capitalize first letter of each word, join back
    return str
        .split(" ")
        .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
        .join(" ");
}

/**
 * Count vowels in a string
 * Counts both uppercase and lowercase vowels (a, e, i, o, u)
 * @param {string} str - Input string
 * @returns {object} - Count breakdown and total
 */
function countVowels(str) {
    // Input validation
    if (typeof str !== "string") {
        return {
            error: `Expected string, received ${typeof str}`,
            success: false
        };
    }

    // Convert to lowercase for counting
    const lowerStr = str.toLowerCase();
    const vowels = ["a", "e", "i", "o", "u"];
    
    // Count each vowel individually
    const vowelCount = {
        a: 0,
        e: 0,
        i: 0,
        o: 0,
        u: 0,
        total: 0
    };

    // Iterate through string and count vowels
    for (let i = 0; i < lowerStr.length; i++) {
        const char = lowerStr[i];
        if (vowels.includes(char)) {
            vowelCount[char]++;
            vowelCount.total++;
        }
    }

    return {
        success: true,
        original: str,
        length: str.length,
        vowelBreakdown: {
            a: vowelCount.a,
            e: vowelCount.e,
            i: vowelCount.i,
            o: vowelCount.o,
            u: vowelCount.u
        },
        totalVowels: vowelCount.total,
        consonantCount: str.length - vowelCount.total,
        vowelPercentage: ((vowelCount.total / str.length) * 100).toFixed(2) + "%"
    };
}

/**
 * Reverse a string
 * Multiple reversal methods available
 * @param {string} str - Input string
 * @param {string} method - Method: 'split', 'array', or 'loop'
 * @returns {object} - Reversed string and method info
 */
function reverseString(str, method = "split") {
    // Input validation
    if (typeof str !== "string") {
        return {
            error: `Expected string, received ${typeof str}`,
            success: false
        };
    }

    if (str.length === 0) {
        return {
            success: true,
            original: str,
            reversed: "",
            method: method,
            length: 0
        };
    }

    let reversed;

    // Different reversal methods
    switch (method.toLowerCase()) {
        case "split":
            // Method 1: split(), reverse(), join()
            reversed = str.split("").reverse().join("");
            break;
        
        case "array":
            // Method 2: Spread operator with array methods
            reversed = [...str].reverse().join("");
            break;
        
        case "loop":
            // Method 3: Traditional for loop
            reversed = "";
            for (let i = str.length - 1; i >= 0; i--) {
                reversed += str[i];
            }
            break;
        
        default:
            return {
                error: `Unknown method "${method}". Use 'split', 'array', or 'loop'`,
                success: false
            };
    }

    return {
        success: true,
        original: str,
        reversed: reversed,
        method: method,
        length: str.length,
        isPalindrome: str.toLowerCase() === reversed.toLowerCase()
    };
}


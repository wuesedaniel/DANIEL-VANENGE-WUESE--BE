/**
 * Function to calculate grade using IF/ELSE statements
 * @param {number} score - Student score (0-100)
 * @returns {object} - Object containing grade, letterGrade, and feedback
 */
function getGradeIfElse(score) {
    // Grade calculation using if/else
    let letterGrade;
    let description;
    let colorCode;

    if (score >= 90) {
        letterGrade = "A";
        description = "Excellent";
        colorCode = "🟢";
    } else if (score >= 80) {
        letterGrade = "B";
        description = "Good";
        colorCode = "🟢";
    } else if (score >= 70) {
        letterGrade = "C";
        description = "Satisfactory";
        colorCode = "🟡";
    } else if (score >= 60) {
        letterGrade = "D";
        description = "Pass";
        colorCode = "🟠";
    } else {
        letterGrade = "F";
        description = "Fail";
        colorCode = "🔴";
    }

    return {
        success: true,
        score: score,
        letterGrade: letterGrade,
        description: description,
        colorCode: colorCode,
        feedback: `Score ${score}/100 = ${letterGrade} (${description})`
    };
}


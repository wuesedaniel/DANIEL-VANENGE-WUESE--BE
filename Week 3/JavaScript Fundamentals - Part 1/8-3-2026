/**
 * Function to calculate grade using SWITCH statements
 * @param {number} score - Student score (0-100)
 * @returns {object} - Object containing grade, letterGrade, and feedback
 */
function getGradeSwitch(score) {
    // Convert score to grade range (0-10 scale for switch)
    const gradeRange = Math.floor(score / 10);

    let letterGrade;
    let description;
    let colorCode;
    let gradePoints;

    // Using switch statement
    switch (gradeRange) {
        case 10:
        case 9:
            letterGrade = "A";
            description = "Excellent";
            colorCode = "🟢";
            gradePoints = "4.0";
            break;
        case 8:
            letterGrade = "B";
            description = "Good";
            colorCode = "🟢";
            gradePoints = "3.0";
            break;
        case 7:
            letterGrade = "C";
            description = "Satisfactory";
            colorCode = "🟡";
            gradePoints = "2.0";
            break;
        case 6:
            letterGrade = "D";
            description = "Pass";
            colorCode = "🟠";
            gradePoints = "1.0";
            break;
        default:
            letterGrade = "F";
            description = "Fail";
            colorCode = "🔴";
            gradePoints = "0.0";
    }

    return {
        success: true,
        score: score,
        letterGrade: letterGrade,
        description: description,
        colorCode: colorCode,
        gradePoints: gradePoints,
        feedback: `Score ${score}/100 = ${letterGrade} (${description}) | GPA: ${gradePoints}`
    };
}


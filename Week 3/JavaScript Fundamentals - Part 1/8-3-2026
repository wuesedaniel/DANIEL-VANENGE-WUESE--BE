/**
 * Complete string analysis function
 * @param {string} str - Input string
 * @returns {object} - Comprehensive analysis
 */
function analyzeString(str) {
    if (typeof str !== "string") {
        return {
            error: `Expected string, received ${typeof str}`,
            success: false
        };
    }

    const titleCased = toTitleCase(str);
    const vowelInfo = countVowels(str);
    const reversed = reverseString(str, "split");

    return {
        success: true,
        original: str,
        length: str.length,
        uppercase: str.toUpperCase(),
        lowercase: str.toLowerCase(),
        titleCase: titleCased,
        reversed: reversed.reversed,
        isPalindrome: reversed.isPalindrome,
        wordCount: str.trim().split(/\s+/).length,
        vowelStatistics: vowelInfo.success ? {
            total: vowelInfo.totalVowels,
            percentage: vowelInfo.vowelPercentage,
            breakdown: vowelInfo.vowelBreakdown
        } : null
    };
}


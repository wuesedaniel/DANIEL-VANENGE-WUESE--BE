/**
 * Process multiple student grades and provide statistics
 * @param {array} scores - Array of student scores
 * @returns {object} - Statistics and individual results
 */
function processBatchGrades(scores) {
    const results = scores.map(score => getGradeSwitch(score));

    // Calculate statistics
    const validScores = results.map(g => g.score);
    const average = validScores.length > 0 ? validScores.reduce((a, b) => a + b, 0) / validScores.length : 0;
    const highest = Math.max(...validScores);
    const lowest = Math.min(...validScores);
    const gradeDistribution = {};

    results.forEach(grade => {
        gradeDistribution[grade.letterGrade] = (gradeDistribution[grade.letterGrade] || 0) + 1;
    });

    return {
        totalInputs: scores.length,
        statistics: {
            average: average.toFixed(2),
            highest: highest,
            lowestValid: lowest,
            distribution: gradeDistribution
        },
        results: results
    };
}


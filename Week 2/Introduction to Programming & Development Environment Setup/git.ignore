//git.ignore//
# Backend Development Gitignore
# This file specifies which files and directories should not be tracked by git

# Node.js dependencies
node_modules/
package-lock.json
npm-debug.log

# Python dependencies
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv

# Environment variables
.env
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store

# Build and dist directories
dist/
build/
*.log

# OS files
Thumbs.db
